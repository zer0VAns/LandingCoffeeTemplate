---
const opiniones = [
  {
    texto: 'El mejor café que probé en la ciudad. El ambiente es cálido y el latte art impecable.',
    autor: 'María González',
    rol: 'Clienta habitual',
  },
  {
    texto: 'Vengo cada mañana antes de trabajar. El cold brew se volvió parte de mi rutina.',
    autor: 'Diego Fernández',
    rol: 'Cliente frecuente',
  },
  {
    texto: 'Se nota que cuidan cada detalle, desde el tueste hasta el servicio. Totalmente recomendado.',
    autor: 'Sofía Ramírez',
    rol: 'Bloguera gastronómica',
  },
];
---

<section id="opiniones" class="py-24 md:py-32 px-6 md:px-10 bg-cream">
  <div class="mx-auto max-w-6xl">
    <div class="text-center max-w-xl mx-auto mb-14">
      <p class="text-latte tracking-[0.25em] text-xs uppercase mb-4">Testimonios</p>
      <h2 class="font-display text-3xl md:text-4xl font-semibold text-espresso">Lo que dicen de nosotros</h2>
    </div>

    <div class="testimonial-grid grid grid-cols-1 md:grid-cols-3 gap-6">
      {opiniones.map((op) => (
        <blockquote class="testimonial-card bg-white rounded-2xl p-8 shadow-sm border border-espresso/5">
          <div class="text-latte text-sm mb-4" aria-hidden="true">★★★★★</div>
          <p class="text-espresso/80 leading-relaxed italic mb-6">"{op.texto}"</p>
          <footer class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-full bg-roast/15 text-roast flex items-center justify-center font-display font-semibold">
              {op.autor.charAt(0)}
            </div>
            <div>
              <p class="text-sm font-semibold text-espresso">— {op.autor}</p>
              <p class="text-xs text-espresso/50">{op.rol}</p>
            </div>
          </footer>
        </blockquote>
      ))}
    </div>
  </div>
</section>

<script>

</script>
