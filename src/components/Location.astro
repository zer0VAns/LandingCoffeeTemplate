---
const info = [
  { label: "Dirección", value: "Av. Siempre Viva 742, Centro" },
  { label: "Horario", value: "Lun a Sáb · 8:00 – 20:00" },
  { label: "Teléfono", value: "+54 9 264 000 0000" },
];
---

<section
  id="ubicacion"
  class="relative overflow-hidden bg-mocha grain px-5 py-20 sm:px-6 md:px-10 md:py-32"
>
  <div class="mx-auto max-w-6xl">
    <div class="mb-12 text-center md:mb-20 md:text-left">
      <p class="location-subtitle mb-3 text-xs uppercase tracking-[0.3em] text-latte">
        Visítanos
      </p>
      <h2 class="location-title font-display text-3xl font-semibold text-cream sm:text-4xl md:text-5xl">
        Encontranos aquí
      </h2>
    </div>

    <div class="grid grid-cols-1 gap-8 lg:grid-cols-[1.15fr_0.85fr] lg:gap-16 lg:items-start">
      <div
        class="location-map relative min-h-[280px] overflow-hidden rounded-2xl shadow-2xl ring-1 ring-cream/10 sm:min-h-[340px] lg:min-h-[480px]"
      >
        <iframe
          title="Ubicación de Café Aroma"
          src="https://www.google.com/maps?q=San%20Juan%2C%20Argentina&output=embed"
          class="h-full min-h-[280px] w-full border-0 grayscale-[15%] contrast-[1.05] saturate-[0.8] sm:min-h-[340px] lg:min-h-[480px]"
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"></iframe>
        <div class="pointer-events-none absolute inset-0 bg-mocha/25 mix-blend-multiply"></div>
        <div class="pointer-events-none absolute inset-0 rounded-2xl ring-1 ring-inset ring-cream/10"></div>
      </div>

      <div class="location-ticket flex items-center justify-center lg:items-start">
        <div class="ticket-set w-full max-w-sm">

          <div
            class="ticket relative w-full bg-cream px-5 pt-6 pb-7 text-mocha shadow-2xl sm:px-7 sm:pt-8 sm:pb-9 [clip-path:polygon(0%_0%,100%_0%,100%_100%,95%_96%,90%_100%,85%_96%,80%_100%,75%_96%,70%_100%,65%_96%,60%_100%,55%_96%,50%_100%,45%_96%,40%_100%,35%_96%,30%_100%,25%_96%,20%_100%,15%_96%,10%_100%,5%_96%,0%_100%)]"
          >
            <div class="mb-6 flex items-center justify-between border-b border-dashed border-mocha/25 pb-4">
              <span class="font-display text-base font-semibold sm:text-lg">Café Aroma</span>
              <span class="font-mono text-[10px] uppercase tracking-[0.2em] text-mocha/45">
                Comanda
              </span>
            </div>

            <ul class="space-y-4 sm:space-y-5">
              {info.map((item, i) => (
                <li class="flex items-start gap-3.5">
                  <span class="mt-0.5 shrink-0 text-mocha/60">
                    {i === 0 && (
                      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
                        <path d="M12 21s-7-6.1-7-11.5A7 7 0 0 1 19 9.5C19 14.9 12 21 12 21Z" />
                        <circle cx="12" cy="9.5" r="2.4" />
                      </svg>
                    )}
                    {i === 1 && (
                      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
                        <circle cx="12" cy="12" r="8.5" />
                        <path d="M12 7.5V12l3 2" />
                      </svg>
                    )}
                    {i === 2 && (
                      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
                        <path d="M5.5 4h3l1.5 4.5-2 1.5a12 12 0 0 0 6 6l1.5-2 4.5 1.5v3c0 1-1 1.5-2 1.5C10.5 20 4 13.5 4 6.5c0-1 .5-2 1.5-2.5Z" />
                      </svg>
                    )}
                  </span>
                  <div>
                    <p class="mb-0.5 text-[9px] uppercase tracking-wider text-mocha/45 sm:text-[10px]">
                      {item.label}
                    </p>
                    <p class="font-mono text-sm leading-snug sm:text-[15px]">{item.value}</p>
                  </div>
                </li>
              ))}
            </ul>
          </div>

          <a
            href="https://wa.me/5492640000000"
            target="_blank"
            rel="noopener noreferrer"
            class="wa-stub group relative -mt-px flex w-full items-center gap-3 px-5 pt-4 pb-5 rounded-b-md bg-cream text-mocha shadow-md sm:gap-3.5 sm:pl-7 sm:pr-6 [clip-path:polygon(0%_16%,5%_0%,10%_16%,15%_0%,20%_16%,25%_0%,30%_16%,35%_0%,40%_16%,45%_0%,50%_16%,55%_0%,60%_16%,65%_0%,70%_16%,75%_0%,80%_16%,85%_0%,90%_16%,95%_0%,100%_16%,100%_100%,0%_100%)]"
          >
            <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full border border-mocha/20">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="#25D366">
                <path d="M12.04 2C6.58 2 2.13 6.45 2.13 11.91c0 1.75.46 3.45 1.32 4.95L2 22l5.29-1.39a9.9 9.9 0 0 0 4.75 1.21h.01c5.46 0 9.91-4.45 9.91-9.91 0-2.65-1.03-5.14-2.9-7.01A9.82 9.82 0 0 0 12.04 2Zm0 18.06h-.01a8.2 8.2 0 0 1-4.18-1.14l-.3-.18-3.14.82.84-3.06-.19-.31a8.17 8.17 0 0 1-1.26-4.36c0-4.53 3.69-8.22 8.24-8.22 2.2 0 4.27.86 5.82 2.42a8.15 8.15 0 0 1 2.41 5.81c0 4.53-3.69 8.22-8.23 8.22Z" />
              </svg>
            </span>
            <span class="flex flex-col leading-tight">
              <span class="mb-0.5 font-mono text-[9px] uppercase tracking-[0.2em] text-mocha/40">
                Talón · contacto directo
              </span>
              <span class="font-display text-[13px] font-semibold decoration-mocha/30 underline-offset-4 group-hover:underline sm:text-sm">
                Escribinos por WhatsApp
              </span>
            </span>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

