---
const currentYear = new Date().getFullYear();
---

<footer class="bg-espresso text-cream/70 px-6 md:px-10 py-14">
  <div class="mx-auto max-w-6xl grid grid-cols-1 sm:grid-cols-3 gap-10 sm:gap-6 text-center sm:text-left">
    <div>
      <p class="font-display text-xl text-cream mb-3">NombreMarca</p>
      <p class="text-sm leading-relaxed max-w-xs mx-auto sm:mx-0">
        Café de especialidad desde 2018. Tostado propio, servido con dedicación.
      </p>
    </div>

    <div>
      <p class="text-xs uppercase tracking-wide text-cream/40 mb-3">Horarios</p>
      <p class="text-sm">Lunes a Sábado</p>
      <p class="text-sm">8:00 – 20:00</p>
      <p class="text-sm mt-1">Domingo: cerrado</p>
    </div>

    <div class="flex flex-col items-center sm:items-start">
      <p class="text-xs uppercase tracking-wide text-cream/40 mb-3">Seguinos</p>
      <div class="flex gap-4">
        <a href="#" aria-label="Instagram" class="w-10 h-10 rounded-full border border-cream/20 flex items-center justify-center hover:border-latte hover:text-latte transition-colors duration-300">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <rect x="2" y="2" width="20" height="20" rx="5" />
            <circle cx="12" cy="12" r="4" />
            <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none" />
          </svg>
        </a>
        <a href="#" aria-label="Facebook" class="w-10 h-10 rounded-full border border-cream/20 flex items-center justify-center hover:border-latte hover:text-latte transition-colors duration-300">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z" />
          </svg>
        </a>
        <a href="https://wa.me/5492640000000" target="_blank" rel="noopener" aria-label="WhatsApp" class="w-10 h-10 rounded-full border border-cream/20 flex items-center justify-center hover:border-latte hover:text-latte transition-colors duration-300">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12.04 2C6.58 2 2.13 6.45 2.13 11.91c0 1.75.46 3.45 1.32 4.95L2 22l5.29-1.39a9.9 9.9 0 0 0 4.75 1.21h.01c5.46 0 9.91-4.45 9.91-9.91 0-2.65-1.03-5.14-2.9-7.01A9.82 9.82 0 0 0 12.04 2Z" />
          </svg>
        </a>
      </div>
    </div>
  </div>

  <div class="mx-auto max-w-6xl border-t border-cream/10 mt-10 pt-6 text-center text-xs text-cream/40">
    © {currentYear} NombreMarca. Todos los derechos reservados.
  </div>
</footer>
